# ---------------------------------------------------------------------------
# GitHub access — use a GitHub App install scoped to moltbankhq/moltbank-kb.
# Contents: READ AND WRITE (write is required for temp_propose_change to
# append entries to temp/<owner>.md). See DEPLOY.md for setup.
# ---------------------------------------------------------------------------
# Option A (recommended, production): GitHub App install
GITHUB_APP_ID=
GITHUB_APP_INSTALLATION_ID=
# Private key PEM — keep as a single line with \n escapes, or paste the full
# PEM (including BEGIN/END lines). Vercel handles multiline env vars fine.
GITHUB_APP_PRIVATE_KEY=

# Option B (simpler, dev/local): fine-grained PAT with contents:write on moltbank-kb
GITHUB_TOKEN=

# Which repo and branch to mirror / write to
GITHUB_REPO=moltbankhq/moltbank-kb
GITHUB_BRANCH=main

# Shared secret for GitHub webhook HMAC validation
GITHUB_WEBHOOK_SECRET=

# Commit identity used by temp_propose_change. Keep it distinct from human
# committers so branch-protection rules can treat MCP-sourced commits
# differently (path-scope CI check).
MCP_COMMIT_AUTHOR_NAME=kb-mcp-bot
MCP_COMMIT_AUTHOR_EMAIL=bot@moltbank.bot

# ---------------------------------------------------------------------------
# MCP auth — JSON map of bearer tokens → consumer config.
# visibility: public | internal | secret (tier hierarchy enforced server-side)
# owner (optional): cap | jesus | daniel | marielba — enables temp_propose_change
#   and scopes writes to temp/<owner>.md exclusively.
# operations (optional): { ga4?, linear_read?, linear_write? } — gates the
#   operations_* tools.
# ---------------------------------------------------------------------------
MCP_TOKENS={"tok_replace_me":{"name":"paperclip-prod","max_visibility":"internal","rate_limit_per_min":60}}

# Example with write + ops scopes:
#   {
#     "tok_daniel_agent_xxx": {
#       "name": "daniel-agent",
#       "max_visibility": "internal",
#       "rate_limit_per_min": 60,
#       "owner": "daniel",
#       "operations": { "ga4": true, "linear_read": true, "linear_write": true }
#     }
#   }

# Separate admin token for the manual-refresh endpoint
ADMIN_TOKEN=replace-me-with-a-long-random-string

# ---------------------------------------------------------------------------
# Operations integrations (optional — only needed if any token has the
# corresponding operations.* scope set to true).
# ---------------------------------------------------------------------------

# Google Analytics 4 — service account with Viewer role on property 529850183.
GA4_PROPERTY_ID=529850183
GA4_SERVICE_ACCOUNT_KEY=

# Linear — workspace-level API key with read + write on the target workspace.
LINEAR_API_KEY=

# ---------------------------------------------------------------------------
# Runtime tuning
# ---------------------------------------------------------------------------
LOG_LEVEL=info
CACHE_TTL_SECONDS=600
VAULT_CACHE_DIR=/tmp/moltbank-kb
